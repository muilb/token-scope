# Copy this to `.env` and fill in real values. `.env` is gitignored — never commit it.
# Loaded via `npm start` (which runs `node --env-file=.env server.js`, Node 20+).

# Bind address. 0.0.0.0 = reachable from the LAN; 127.0.0.1 = this machine only.
HOST=0.0.0.0

# Port the dashboard + ingest API listen on.
PORT=8787

# Shared secret clients send as X-Ingest-Key. REQUIRED when HOST is not 127.0.0.1,
# otherwise anyone on the LAN can POST usage. Use a long random string.
INGEST_KEY=change-me-to-a-long-random-secret

# Admin secret protecting the pricing settings page (/admin) and price edits
# (POST /admin/pricing). DIFFERENT from INGEST_KEY — do not give this to members.
# Empty = admin page is open (dev / trusted-LAN only).
ADMIN_KEY=change-me-to-another-long-random-secret

# SQLite file. Default is ./data/usage.db if omitted.
# DB_PATH=./data/usage.db
